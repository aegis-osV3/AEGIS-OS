# AEGIS OS V3 production template
# Replace every placeholder with externally managed secret material before use.
APP_ENV=production
ENVIRONMENT_PROFILE=production
APP_NAME=AegisOS API
APP_VERSION=3.0.0
API_V1_PREFIX=/api/v1

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000
CORS_ORIGINS=https://replace-with-your-aegis-domain.example

POSTGRES_DB=aegisos
POSTGRES_USER=aegisos
POSTGRES_PORT=5432
POSTGRES_PASSWORD=replace-with-production-database-password
DATABASE_URL=postgresql+psycopg://aegisos:replace-with-production-database-password@postgres:5432/aegisos

JWT_SECRET_KEY=replace-with-production-jwt-signing-secret-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

NEXT_PUBLIC_API_BASE_URL=https://replace-with-your-aegis-domain.example/api/v1
