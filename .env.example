# AEGIS OS V3.0 environment template
# Copy to .env for local evaluation. Replace placeholder secrets before shared or production use.

# Application
APP_ENV=development
ENVIRONMENT_PROFILE=development
APP_NAME=AegisOS API
APP_VERSION=3.0.0
API_V1_PREFIX=/api/v1

# Backend runtime
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
POSTGRES_DB=aegisos
POSTGRES_USER=aegisos
POSTGRES_PORT=5432
POSTGRES_PASSWORD=replace-with-a-strong-database-password
DATABASE_URL=postgresql+psycopg://aegisos:replace-with-a-strong-database-password@postgres:5432/aegisos

# Authentication
JWT_SECRET_KEY=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
